# Copy to `.env` in this folder (never commit `.env` — it is gitignored).
# The API loads this file first via `src/load-env.ts` before other modules.
# On Replit you can also set the same names under Secrets (they override .env if both exist).

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Groq — DM story assistant (https://console.groq.com/keys)
GROQ_API_KEY=
